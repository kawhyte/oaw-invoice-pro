# Template for .env.staging.local and .env.prod.local (used by package.json scripts).
# Real values: Supabase dashboard (Project Settings -> API), Resend dashboard, Vercel env vars.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Redirects ALL outgoing email to this address. Set in both local profiles (safety);
# the deployed app on Vercel uses its own env vars and sends real email.
RESEND_TO_OVERRIDE=
CRON_SECRET=
